  max-width: var(--max);
  margin: 14px auto 40px;
  padding: 18px 18px 36px;
  text-align: center;
  color: rgba(46,46,46,.38);
  font-size: 12px;
}
.sep{ opacity: .5; padding: 0 6px; }

.easter{
  position: fixed;
  left: 50%;
  bottom: 18px;
  transform: translateX(-50%);
  padding: 10px 12px;
  border-radius: 999px;
  background: rgba(255,255,255,.56);
  border: 1px solid rgba(46,46,46,.10);
  box-shadow: 0 18px 50px rgba(39, 33, 29, .14);
  color: rgba(46,46,46,.78);
  font-size: 13px;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  opacity: 0;
  transition: opacity 220ms ease, transform 220ms ease;
  pointer-events: none;
}
.easter.is-on{
  opacity: 1;
  transform: translateX(-50%) translateY(-2px);
}

.cursor-dot, .cursor-ring{
  position: fixed;
  top: 0;
  left: 0;
  pointer-events: none;
  z-index: 50;
  opacity: 0;
}
.cursor-dot{
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: rgba(46,46,46,.55);
  transform: translate3d(-50%, -50%, 0);
}
.cursor-ring{
  width: 34px;
  height: 34px;
  border-radius: 999px;
  border: 1.5px solid rgba(46,46,46,.22);
  transform: translate3d(-50%, -50%, 0);
  transition: width 160ms ease, height 160ms ease, border-color 160ms ease, opacity 160ms ease;
}
body.has-custom-cursor .cursor-dot,
body.has-custom-cursor .cursor-ring{ opacity: 1; }
body.is-hovering .cursor-ring{
  width: 44px;
  height: 44px;
  border-color: rgba(255,182,193,.55);
}

[data-reveal]{
  opacity: 0;
  transform: translateY(10px);
}
body.is-ready [data-reveal]{
  animation: riseIn 600ms cubic-bezier(.2,.9,.2,1) both;
  animation-delay: var(--d, 0ms);
}
@keyframes riseIn{
  from{ opacity: 0; transform: translateY(10px); }
  to{ opacity: 1; transform: translateY(0); }
}

@media (prefers-reduced-motion: reduce){
  *{ scroll-behavior: auto !important; animation: none !important; transition: none !important; }
  .bg-parallax{ transform: none !important; }
}

@media (max-width: 980px){
  .carousel-shell{ width: min(95vw, var(--max)); }
}

@media (max-width: 700px){
  .topbar{ top: 10px; }
  .nav-toggle{ display: inline-grid; place-items: center; }
  .topbar-tagline{ display: none; }
  .nav{
    position: absolute;
    right: 18px;
    top: 64px;
    padding: 10px;
    border-radius: 16px;
    border: 1px solid rgba(46,46,46,.10);
    background: rgba(255,255,255,.56);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 18px 50px rgba(39, 33, 29, .14);
    display: none;
    flex-direction: column;
    gap: 8px;
    min-width: 140px;
  }
  body.menu-open .nav{ display: flex; }
  .hero-inner{ padding-top: 28px; }

  .arrow{
    top: auto;
    bottom: 12px;
    transform: none;
  }
  .arrow:hover{ transform: scale(1.04); }
  .arrow-left{ left: 14px; }
  .arrow-right{ right: 14px; }

  .social-item{ width: 104px; }
}

